---
import ScrimbaAd from './ScrimbaAd.astro';
import LearnAstroAd from './LearnAstroAd.astro';
import AstroJobsAd from './AstroJobsAd.astro';

const ads = [
	{ component: ScrimbaAd, weight: 0.4 },
	{ component: LearnAstroAd, weight: 0.4 },
	{ component: AstroJobsAd, weight: 0.2 },
];
const totalWeight = ads.reduce((sum, ad) => sum + ad.weight, 0);
let random = Math.random() * totalWeight;
const Ad = ads.find((ad) => (random -= ad.weight) < 0)!.component;
---

<Ad />
