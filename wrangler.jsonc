{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "astro-docs",
	"compatibility_date": "2026-05-06",
	"build": {
		"command": "NODE_OPTIONS=--max_old_space_size=8192 pnpm build"
	},
	"assets": {
		"directory": "./dist",
		"not_found_handling": "404-page"
	},
	"observability": {
		"enabled": true
	}
}
